# Smart Contract Deployment
PRIVATE_KEY=your_wallet_private_key_here

# Frontend Configuration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Contract Addresses (deploy and update these)
NEXT_PUBLIC_CONTRACT_ADDRESS_BASE=0x...
NEXT_PUBLIC_CONTRACT_ADDRESS_BASE_SEPOLIA=0x...

# Game Server
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
PORT=3001

# Neynar API (optional for user data fallback)
NEYNAR_API_KEY=your_neynar_api_key

# Base URLs for CORS
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Farcaster Hub (for writing data - optional)
FARCASTER_HUB_URL=https://hub.pinata.cloud